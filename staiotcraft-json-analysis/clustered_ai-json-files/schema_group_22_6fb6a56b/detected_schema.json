{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "uuid": {
      "type": "string"
    },
    "ai_project_name": {
      "type": "string"
    },
    "display_name": {
      "type": "null"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "last_update_time": {
      "type": "string"
    },
    "creation_time": {
      "type": "string"
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "dataset": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "dataset_id": {
                "type": "string"
              }
            },
            "required": [
              "dataset_id",
              "name"
            ]
          },
          "metadata": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "classes": {
                "type": "null"
              }
            },
            "required": [
              "classes",
              "type"
            ]
          },
          "target": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "component": {
                "type": "string"
              },
              "device": {
                "type": "string"
              }
            },
            "required": [
              "component",
              "device",
              "type"
            ]
          },
          "creation_time": {
            "type": "string"
          },
          "last_update_time": {
            "type": "string"
          }
        },
        "required": [
          "creation_time",
          "dataset",
          "last_update_time",
          "metadata",
          "name",
          "target",
          "uuid"
        ]
      }
    },
    "deployments": {
      "type": "array"
    }
  },
  "required": [
    "ai_project_name",
    "creation_time",
    "deployments",
    "description",
    "display_name",
    "last_update_time",
    "models",
    "uuid",
    "version"
  ]
}