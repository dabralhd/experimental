                        "name",
                        "template_id",
                        "version"
                      ]
                    }
                  }
                },
                "required": [
                  "jobs",
                  "type"
                ]
              },
              "configuration": {
                "type": "string"
              },
              "artifacts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reports": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "artifacts",
              "configuration",
              "creation_time",
              "last_update_time",
              "reports",
              "runtime"
            ]
