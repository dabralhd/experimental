{
  "layout": {
    "defaultInstallationFolderBase": "misc",
    "useOverrideInstallPatterns": true,
    "overrideInstallPatterns": [
      {
        "pattern": "(STMicroelectronics|ARM)\\.CMSIS-NN\\..*",
        "folder": "arch/cmsis_nn"
      },
      {
        "pattern": "(STMicroelectronics|ARM)\\.CMSIS-Compiler\\..*",
        "folder": "arch/cmsis_compiler"
      },
      {
        "pattern": "(STMicroelectronics|ARM)\\.CMSIS-DSP\\..*",
        "folder": "arch/cmsis_dsp"
      },
      {
        "pattern": "(STMicroelectronics|ARM)\\.CMSIS\\..*",
        "folder": "arch/cmsis"
      },
      {
        "pattern": "(STMicroelectronics|ARM)\\..*CMSIS.*",
        "folder": "arch"
      },
      {
        "pattern": "STMicroelectronics\\.(.*)_hal_drivers.*",
        "folder": "\\1_drivers"
      },
      {
        "pattern": "STMicroelectronics\\.(.*_dfp).*",
        "folder": "\\1"
      },
      {
        "pattern": "STMicroelectronics\\.utility.*",
        "folder": "utilities"
      },
      {
        "pattern": "STMicroelectronics\\.mw_([^.]+)\\..*",
        "folder": "middleware/\\1"
      },
      {
        "pattern": "STMicroelectronics.filex\\..*",
        "folder": "middleware/filex"
      },
      {
        "pattern": "STMicroelectronics.freertos\\..*",
        "folder": "middleware/freertos"
      },
      {
        "pattern": "STMicroelectronics.levelx\\..*",
        "folder": "middleware/levelx"
      },
      {
        "pattern": "STMicroelectronics.lwip\\..*",
        "folder": "middleware/lwip"
      },
      {
        "pattern": "STMicroelectronics.mbedtls\\..*",
        "folder": "middleware/mbedtls"
      },
      {
        "pattern": "STMicroelectronics.mcuboot\\..*",
        "folder": "middleware/mcuboot"
      },
      {
        "pattern": "STMicroelectronics.stcryptolib\\..*",
        "folder": "middleware/stcryptolib"
      },
      {
        "pattern": "STMicroelectronics.stfcf\\..*",
        "folder": "middleware/stfcf"
      },
      {
        "pattern": "STMicroelectronics.stm32_touchsensing_library\\..*",
        "folder": "middleware/stm32_touchsensing_library"
      },
      {
        "pattern": "STMicroelectronics.usbpd\\..*",
        "folder": "middleware/usbpd"
      },
      {
        "pattern": "STMicroelectronics.usbx\\..*",
        "folder": "middleware/usbx"
      },
      {
        "pattern": "STMicroelectronics.adv_trace\\..*",
        "folder": "utilities/adv_trace"
      },
      {
        "pattern": "STMicroelectronics.basic_stdio\\..*",
        "folder": "utilities/basic_stdio"
      },
      {
        "pattern": "STMicroelectronics.eeprom_emulation\\..*",
        "folder": "utilities/eeprom_emulation"
      },
      {
        "pattern": "STMicroelectronics.sequencer\\..*",
        "folder": "utilities/sequencer"
      },
      {
        "pattern": "STMicroelectronics.syscalls\\..*",
        "folder": "utilities/syscalls"
      },
      {
        "pattern": "STMicroelectronics.thread_safe_libc\\..*",
        "folder": "utilities/thread_safe_libc"
      }
    ],
    "overridePackMappingRules": [
      {
        "selectors": [
          {
            "packVendor": "ARM"
          },
          {
            "packName": "*CMSIS*"
          }
        ],
        "path": "arch/{{packName}}"
      },
      {
        "selectors": [
          {
            "packType": "HAL"
          }
        ],
        "path": "{{packFriendlyName}}"
      },
      {
        "selectors": [
          {
            "packType": "DFP"
          }
        ],
        "path": "{{packFriendlyName}}"
      },
      {
        "selectors": [
          {
            "packType": "PARTDRV"
          }
        ],
        "path": "{{parent}}/{{packFriendlyName}}"
      },
      {
        "selectors": [
          {
            "packType": "MW"
          }
        ],
        "path": "{{parent}}/{{packFriendlyName}}"
      },
      {
        "selectors": [
          {
            "packType": "UTILITY"
          }
        ],
        "path": "{{parent}}/{{packFriendlyName}}"
      },
      {
        "selectors": [
          {
            "packType": "EXAMPLE"
          }
        ],
        "path": "{{parent}}/{{layer}}/{{element}}/{{packFriendlyName}}"
      },
      {
        "selectors": [
          {
            "packType": "HWBOARD"
          }
        ],
        "path": ""
      },
      {
        "selectors": [
          {
            "packType": "HWPART"
          }
        ],
        "path": ""
      },
      {
        "selectors": [
          {
            "packType": "TEMPLATE"
          }
        ],
        "path": ""
      },
      {
        "selectors": [],
        "path": "misc/{{packVendor}}.{{packName}}.{{packVersion}}"
      }
    ],
    "overrideGeneratorMappingRules": [
      {
        "selectors": [
          {
            "generator": "HALCodeGen"
          }
        ],
        "path": "{{SWprj}}/generated/hal/"
      },
      {
        "selectors": [
          {
            "generator": "FreeRTOSCodeGen"
          }
        ],
        "path": "{{SWprj}}/generated/middleware"
      },
      {
        "selectors": [
          {
            "generator": "*"
          },
          {
            "packType": "HAL"
          }
        ],
        "path": "{{SWprj}}/generated/hal"
      },
      {
        "selectors": [
          {
            "generator": "*"
          },
          {
            "packType": "MW"
          }
        ],
        "path": "{{SWprj}}/generated/middleware"
      },
      {
        "selectors": [
          {
            "generator": "*"
          },
          {
            "packType": "PARTDRV"
          }
        ],
        "path": "{{SWprj}}/generated/parts"
      },
      {
        "selectors": [
          {
            "generator": "*"
          },
          {
            "packType": "UTILITY"
          }
        ],
        "path": "{{SWprj}}/generated/utilities"
      },
      {
        "selectors": [
          {
            "generator": "FreeRTOSAppCodeGen"
          }
        ],
        "path": "{{SWprj}}/."
      },
      {
        "selectors": [
          {
            "generator": "*AppCodeGen"
          }
        ],
        "path": "{{SWprj}}/."
      },
      {
        "selectors": [
          {
            "generator": "*"
          }
        ],
        "path": "{{SWprj}}/generated/{{generatorID}}"
      }
    ]
  }
}