        {
            "input": "binary_hsd",
            "model": "classifier",
            "output": "steval-stwinkt1b:mlc",
            "section": "input",
            "name": "hsdatalog_to_unico",
            "comments": "Converts HSD raw data files to input for Unico tool.",
            "version": "1.1.0",
            "uri": "{stedgeai_folder_path}/tools/inputs/HSD_PythonSDK/examples/hsdatalog_to_unico.py",
            "runtime": "python3",
            "help_arguments": [
                {
                    "argument": "acq_folder",
                    "help": "Acquisition folder.",
                    "default": ".",
                    "type": "string"
                }
            ],
            "help_parameters": [
                {
                    "short_option": "-o",
                    "long_option": "--output_folder",
                    "help": "Output folder (this will be created if it doesn't exist).",
                    "type": "string",
                    "default": "."
                },
                {
                    "short_option": "-s",
                    "long_option": "--sensor_name",
                    "help": "Sensor Name - use \"all\" to extract all active sensors data, otherwise select a specific sensor by name.",
                    "type": "string",
                    "default": "all"
                },
                {
                    "short_option": "-st",
                    "long_option": "--start_time",
                    "help": "Start Time - Data conversion will start from this time (seconds)",
                    "type": "int",
                    "default": 0
                },
                {
                    "short_option": "-et",
                    "long_option": "--end_time",
                    "help": "End Time - Data conversion will end up in this time (seconds)",
                    "type": "int",
                    "default": -1
                },
                {
                    "short_option": "-t'",
                    "long_option": "--use_datalog_tags",
                    "is_flag": true,
                    "help": "Enable this flag to include information about annotations taken during acquisition (if any) in the exported data",
                    "default": false
                },
                {
                    "short_option": "-f'",
                    "long_option": "--out_format",
                    "help": "Select exported data format",
                    "type": "string",
                    "choice": ["TXT", "CSV", "TSV"],
                    "case_sensitive": false
                },
                {
                    "short_option": "-d'",
                    "long_option": "--debug",
                    "is_flag": true,
                    "help": "[DEBUG] Check for corrupted data and timestamps",
                    "default": false
                },
                {
                    "short_option": "-h",
                    "long_option": "--help",
                    "is_flag": true,
                    "is_eager": true,
                    "expose_value": false,
                    "callback": "show_help",
                    "help": "Show this message and exit."
                }
            ],
            "tools_parameters": {
                "-o": "{models_folder}/{model_folder}/{dataset_folder}/{log_folder}",
                "-f": "TXT",
                "-t": "",
                "-s": "all",
                "": "{models_folder}/{model_folder}/{logs_folder}/{log_folder}"
            }
        },
