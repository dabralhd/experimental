{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "http://example.com/example.json",
    "type": "object",
    "title": "ST Edge.AI Schema for image classification.",
    "description": "ST Edge.AI Schema to configure image classification jupyter notebook template.",
    "version": "v1",
    "required": [
        "general",
        "dataset",
        "model",
        "model_optimization"
    ],
    "properties": {
        "general": {
            "$id": "#/properties/general",
            "type": "object",
            "title": "General parameters.",
            "description": "General parameters.",
            "default": {},
            "required": [
                "project",
                "model",
                "classes",
                "experiment"
            ],
            "properties": {
                "project": {
                    "$id": "#/properties/general/properties/project",
                    "type": "string",
                    "title": "Project name.",
                    "description": "Name of the project.",
                    "default": ""
                },
                "model": {
                    "$id": "#/properties/general/properties/model",
                    "type": "string",
                    "title": "Model name.",
                    "description": "Name of the model.",
                    "default": ""
                },
                "classes": {
                    "$id": "#/properties/general/properties/classes",
                    "type": "array",
                    "title": "Classes names.",
                    "description": "Name of the classes.",
                    "default": [],
                    "additionalItems": true,
                    "items": {
                        "anyOf": [
                            {
                                "$id": "#/properties/general/properties/classes/items/anyOf/0",
                                "type": "string",
                                "title": "Class name.",
                                "description": "Name of the class.",
                                "default": ""
                            }
                        ]
                    }
                },
                "experiment": {
                    "$id": "#/properties/general/properties/experiment",
                    "type": "string",
                    "title": "Experiment name.",
                    "description": "Name of the experiment.",
                    "default": ""
                }
            }
        },
        "dataset": {
            "$id": "#/properties/dataset",
            "type": "object",
            "title": "Dataset parameters.",
            "description": "Dataset parameters.",
            "default": {},
            "required": [
                "image_size_x",
                "image_size_y",
                "image_size_z",
                "validation_split",
                "class_mode",
                "color_mode",
                "seed",
                "batch_size",
                "shuffle"
            ],
            "properties": {
                "image_size_x": {
                    "$id": "#/properties/dataset/properties/image_size_x",
                    "type": "integer",
                    "title": "Image size X.",
                    "description": "Integer. Horizontal size of the image.",
                    "default": 160
                },
                "image_size_y": {
                    "$id": "#/properties/dataset/properties/image_size_y",
                    "type": "integer",
                    "title": "Image size Y.",
                    "description": "Integer. Vertical size of the image.",
                    "default": 160
                },
                "image_size_z": {
                    "$id": "#/properties/dataset/properties/image_size_z",
                    "type": "integer",
                    "title": "Image size Z.",
                    "description": "Integer. Number of channels of the image. Valid values: 1, 3, 4",
                    "default": 3
                },
                "validation_split": {
                    "$id": "#/properties/dataset/properties/validation_split",
                    "type": "number",
                    "title": "Validation split.",
                    "description": "Float. Fraction of images reserved for validation (strictly between 0 and 1).",
                    "default": 0.20
                },
                "class_mode": {
                    "$id": "#/properties/dataset/properties/class_mode",
                    "type": "string",
                    "title": "Class mode.",
                    "description": "Class mode.",
                    "enum": [
                        "categorical",
                        "binary",
                        "sparse",
                        "input"
                    ],
                    "default": "categorical"
                },
                "color_mode": {
                    "$id": "#/properties/dataset/properties/color_mode",
                    "type": "string",
                    "title": "Color mode.",
                    "description": "Color mode.",
                    "enum": [
                        "grayscale",
                        "rgb",
                        "rgba"
                    ],
                    "default": "rgb"
                },
                "seed": {
                    "$id": "#/properties/dataset/properties/seed",
                    "type": ["integer", "null"],
                    "title": "Seed.",
                    "description": "Integer. Optional random seed for shuffling and transformations.",
                    "default": "null"
                },
                "batch_size": {
                    "$id": "#/properties/dataset/properties/batch_size",
                    "type": "integer",
                    "title": "Batch size.",
                    "description": "Integer. Size of the batches of data.",
                    "default": 32
                },
                "shuffle": {
                    "$id": "#/properties/dataset/properties/shuffle",
                    "type": "boolean",
                    "title": "Shuffle.",
                    "description": "Boolean. Whether to shuffle the data.",
                    "default": true
                }
            }
        },
        "model": {
            "$id": "#/properties/model",
            "type": "object",
            "title": "Model parameters.",
            "description": "Model parameters.",
            "default": {},
            "required": [
                "network",
                "alpha",
                "include_top",
                "optimizer",
                "learning_rate",
                "training_metric",
                "training_loss",
                "top_layer_activation_function",
                "early_stopping_metric",
                "early_stopping_mode",
                "early_stopping_patience",
                "early_stopping_restore_best_weights",
                "initial_epoch",
                "epochs"
            ],
            "properties": {
                "network": {
                    "$id": "#/properties/model/properties/network",
                    "type": "string",
                    "title": "Network.",
                    "description": "Network.",
                    "enum": [
                        "DenseNet121",
                        "DenseNet169",
                        "DenseNet201",
                        "InceptionV3",
                        "MobileNet",
                        "MobileNetV2",
                        "ResNet101",
                        "ResNet101V2",
                        "ResNet152",
                        "ResNet152V2",
                        "ResNet50",
                        "ResNet50V2",
                        "VGG16",
                        "VGG19",
                        "Xception"
                    ],
                    "default": "MobileNetV2"
                },
                "alpha": {
                    "$id": "#/properties/model/properties/alpha",
                    "type": "number",
                    "title": "Convolution alpha.",
                    "description": "Float. Multiplier for kernel convolution.",
                    "default": 0.35
                },
                "include_top": {
                    "$id": "#/properties/model/properties/include_top",
                    "type": "boolean",
                    "title": "Include last layer.",
                    "description": "Boolean. Wether to include the last convolutional layer of the network (for classification).",
                    "default": false
                },
                "optimizer":  {
                    "$id": "#/properties/model/properties/optimizer",
                    "type": "string",
                    "title": "Optimizer.",
                    "description": "Optimizer.",
                    "enum": [
                        "Adadelta",
                        "Adagrad",
                        "Adam",
                        "Adamax",
                        "Ftrl",
                        "Nadam",
                        "RMSprop",
                        "SGD"
                    ],
                    "default": "Adam"
                },
                "learning_rate": {
                    "$id": "#/properties/model/properties/learning_rate",
                    "type": "number",
                    "title": "Learning rate.",
                    "description": "Float. Learning rate.",
                    "default": 1e-4
                },
                "training_metric": {
                    "$id": "#/properties/model/properties/training_metric",
                    "type": "string",
                    "title": "Metric name.",
                    "description": "Name of the metric.",
                    "enum": [
                        "accuracy",
                        "crossentropy",
                        "AUC",
                        "Accuracy",
                        "BinaryAccuracy",
                        "BinaryCrossentropy",
                        "CategoricalAccuracy",
                        "CategoricalCrossentropy",
                        "CategoricalHinge",
                        "CosineSimilarity",
                        "FalseNegatives",
                        "FalsePositives",
                        "Hinge",
                        "KLDivergence",
                        "LogCoshError",
                        "Mean",
                        "MeanAbsoluteError",
                        "MeanAbsolutePercentageError",
                        "MeanIoU",
                        "MeanRelativeError",
                        "MeanSquaredError",
                        "MeanSquaredLogarithmicError",
                        "MeanTensor",
                        "Metric",
                        "Poisson",
                        "Precision",
                        "PrecisionAtRecall",
                        "Recall",
                        "RecallAtPrecision",
                        "RootMeanSquaredError",
                        "SensitivityAtSpecificity",
                        "SparseCategoricalAccuracy",
                        "SparseCategoricalCrossentropy",
                        "SparseTopKCategoricalAccuracy",
                        "SpecificityAtSensitivity",
                        "SquaredHinge",
                        "Sum",
                        "TopKCategoricalAccuracy",
                        "TrueNegatives",
                        "TruePositives"
                    ],
                    "default": "accuracy"
                },
                "training_loss": {
                    "$id": "#/properties/model/properties/training_loss",
                    "type": "string",
                    "title": "Loss function.",
                    "description": "Loss function.",
                    "enum": [
                        "KLD",
                        "MAE",
                        "MAPE",
                        "MSE",
                        "MSLE",
                        "binary_crossentropy",
                        "categorical_crossentropy",
                        "categorical_hinge",
                        "cosine_similarity",
                        "deserialize",
                        "get",
                        "hinge",
                        "huber",
                        "kl_divergence",
                        "kld",
                        "kullback_leibler_divergence",
                        "log_cosh",
                        "logcosh",
                        "mae",
                        "mape",
                        "mean_absolute_error",
                        "mean_absolute_percentage_error",
                        "mean_squared_error",
                        "mean_squared_logarithmic_error",
                        "mse",
                        "msle",
                        "poisson",
                        "serialize",
                        "sparse_categorical_crossentropy",
                        "squared_hinge"
                    ],
                    "default": "categorical_crossentropy"
                },
                "top_layer_activation_function":  {
                    "$id": "#/properties/model/properties/top_layer_activation_function",
                    "type": "string",
                    "title": "Activation function.",
                    "description": "Activation function.",
                    "enum": [
                        "elu",
                        "exponential",
                        "gelu",
                        "hard_sigmoid",
                        "linear",
                        "relu",
                        "selu",
                        "sigmoid",
                        "softmax",
                        "softplus",
                        "softsign",
                        "swish",
                        "tanh"
                    ],
                    "default": "linear"
                },
                "early_stopping_metric":  {
                    "$id": "#/properties/model/properties/early_stopping_metric",
                    "type": "string",
                    "title": "Early Stopping metric.",
                    "description": "Metric used by the early stopping.",
                    "enum": [
                        "val_accuracy",
                        "val_loss"
                    ],
                    "default": "val_accuracy"
                },
                "early_stopping_mode": {
                    "$id": "#/properties/model/properties/early_stopping_mode",
                    "type": "string",
                    "title": "Early Stopping mode.",
                    "description": "Threshold on the metric used by the early stopping.",
                    "default": [
                        "auto",
                        "min",
                        "max"
                    ]
                },
                "early_stopping_patience": {
                    "$id": "#/properties/model/properties/early_stopping_patience",
                    "type": "integer",
                    "title": "Early Stopping patience.",
                    "description": "Number of epochs with no improvement after which training will be stopped.",
                    "default": 0
                },
                "early_stopping_restore_best_weights": {
                    "$id": "#/properties/model/properties/early_stopping_restore_best_weights",
                    "type": "boolean",
                    "title": "Early Stopping restore best weights.",
                    "description": "Whether to restore model weights from the epoch with the best value of the monitored quantity.",
                    "default": true
                },
                "initial_epoch": {
                    "$id": "#/properties/model/properties/initial_epoch",
                    "type": "integer",
                    "title": "Initial epoch.",
                    "description": "Integer. Initial epoch.",
                    "default": 0
                },
                "epochs": {
                    "$id": "#/properties/model/properties/epochs",
                    "type": "integer",
                    "title": "Epochs.",
                    "description": "Integer. Number of epochs.",
                    "default": 100
                }
            }
        },
        "model_optimization": {
            "$id": "#/properties/model_optimization",
            "type": "object",
            "title": "Model optimization parameters.",
            "description": "Model optimization parameters.",
            "default": {},
            "required": [
                "polynomial_decay_initial_sparsity",
                "polynomial_decay_final_sparsity",
                "pruning_epochs"
            ],
            "properties": {
                "polynomial_decay_initial_sparsity": {
                    "$id": "#/properties/model_optimization/properties/polynomial_decay_initial_sparsity",
                    "type": "number",
                    "title": "Polynomial decay initial sparsity.",
                    "description": "Float. Initial sparsity of the polynomial decay.",
                    "default": 0.20
                },
                "polynomial_decay_final_sparsity": {
                    "$id": "#/properties/model_optimization/properties/polynomial_decay_final_sparsity",
                    "type": "number",
                    "title": "Polynomial decay final sparsity.",
                    "description": "Float. Final sparsity of the polynomial decay.",
                    "default": 0.50
                },
                "pruning_epochs": {
                    "$id": "#/properties/model_optimization/properties/pruning_epochs",
                    "type": "integer",
                    "title": "Pruning epochs.",
                    "description": "Integer. Number of epochs used by the pruning.",
                    "default": 100
                }
            }
        }
    }
}
