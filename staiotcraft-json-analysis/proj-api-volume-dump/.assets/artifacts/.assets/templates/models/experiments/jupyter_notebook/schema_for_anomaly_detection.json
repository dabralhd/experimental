{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "http://example.com/example.json",
    "type": "object",
    "title": "ST Edge.AI Schema for anomaly detection.",
    "description": "ST Edge.AI Schema to configure anomaly detection jupyter notebook template.",
    "version": "v1",
    "required": [
        "general",
        "dataset",
        "model"
    ],
    "properties": {
        "general": {
            "$id": "#/properties/general",
            "type": "object",
            "title": "General parameters.",
            "description": "General parameters.",
            "default": {},
            "required": [
                "project",
                "model",
                "experiment"
            ],
            "properties": {
                "project": {
                    "$id": "#/properties/general/properties/project",
                    "type": "string",
                    "title": "Project name.",
                    "description": "Name of the project.",
                    "default": ""
                },
                "model": {
                    "$id": "#/properties/general/properties/model",
                    "type": "string",
                    "title": "Model name.",
                    "description": "Name of the model.",
                    "default": ""
                },
                "experiment": {
                    "$id": "#/properties/general/properties/experiment",
                    "type": "string",
                    "title": "Experiment name.",
                    "description": "Name of the experiment.",
                    "default": ""
                }
            }
        },
        "dataset": {
            "$id": "#/properties/dataset",
            "type": "object",
            "title": "Dataset parameters.",
            "description": "Dataset parameters.",
            "default": {},
            "required": [
                "validation_split",
                "batch_size",
                "shuffle",
                "feature_to_train_and_test",
                "time_series_length"
            ],
            "properties": {
                "validation_split": {
                    "$id": "#/properties/dataset/properties/validation_split",
                    "type": "number",
                    "title": "Validation split.",
                    "description": "Float. Fraction of images reserved for validation (strictly between 0 and 1).",
                    "default": 0.30
                },
                "batch_size": {
                    "$id": "#/properties/dataset/properties/batch_size",
                    "type": "integer",
                    "title": "Batch size.",
                    "description": "Integer. Size of the batches of data.",
                    "default": 128
                },
                "shuffle": {
                    "$id": "#/properties/dataset/properties/shuffle",
                    "type": "boolean",
                    "title": "Shuffle.",
                    "description": "Boolean. Whether to shuffle the data.",
                    "default": true
                },
                "feature_to_train_and_test": {
                    "$id": "#/properties/dataset/properties/feature_to_train_and_test",
                    "type": "string",
                    "title": "Metric to train and test.",
                    "description": "Metric to train and test.",
                    "default": "A_z [g]",
                    "enum":[
                        "G_x [mdps]",
                        "G_y [mdps]",
                        "G_z [mdps]",
                        "A_x [g]",
                        "A_y [g]",
                        "A_z [g]"
                    ]
                },
                "time_series_length": {
                    "$id": "#/properties/dataset/properties/batch_size",
                    "type": "integer",
                    "title": "Batch size.",
                    "description": "Integer. Size of the batches of data.",
                    "default": 32
                }
            }
        },
        "model": {
            "$id": "#/properties/model",
            "type": "object",
            "title": "Model parameters.",
            "description": "Model parameters.",
            "default": {},
            "required": [
                "alpha",
                "optimizer",
                "learning_rate",
                "training_metric",
                "training_loss",
                "early_stopping_metric",
                "early_stopping_mode",
                "early_stopping_patience",
                "initial_epoch",
                "epochs"
            ],
            "properties": {
                "alpha": {
                    "$id": "#/properties/model/properties/alpha",
                    "type": "number",
                    "title": "Convolution alpha.",
                    "description": "Float. Multiplier for kernel convolution.",
                    "default": 1
                },
                "optimizer":  {
                    "$id": "#/properties/model/properties/optimizer",
                    "type": "string",
                    "title": "Optimizer.",
                    "description": "Optimizer.",
                    "enum": [
                        "Adadelta",
                        "Adagrad",
                        "Adam",
                        "Adamax",
                        "Ftrl",
                        "Nadam",
                        "RMSprop",
                        "SGD"
                    ],
                    "default": "Adam"
                },
                "learning_rate": {
                    "$id": "#/properties/model/properties/learning_rate",
                    "type": "number",
                    "title": "Learning rate.",
                    "description": "Float. Learning rate.",
                    "default": 0.001
                },
                "training_metric": {
                    "$id": "#/properties/model/properties/training_metric",
                    "type": "string",
                    "title": "Metric name.",
                    "description": "Name of the metric.",
                    "enum": [
                        "accuracy",
                        "crossentropy",
                        "AUC",
                        "Accuracy",
                        "BinaryAccuracy",
                        "BinaryCrossentropy",
                        "CategoricalAccuracy",
                        "CategoricalCrossentropy",
                        "CategoricalHinge",
                        "CosineSimilarity",
                        "FalseNegatives",
                        "FalsePositives",
                        "Hinge",
                        "KLDivergence",
                        "LogCoshError",
                        "Mean",
                        "MeanAbsoluteError",
                        "MeanAbsolutePercentageError",
                        "MeanIoU",
                        "MeanRelativeError",
                        "MeanSquaredError",
                        "MeanSquaredLogarithmicError",
                        "MeanTensor",
                        "Metric",
                        "Poisson",
                        "Precision",
                        "PrecisionAtRecall",
                        "Recall",
                        "RecallAtPrecision",
                        "RootMeanSquaredError",
                        "SensitivityAtSpecificity",
                        "SparseCategoricalAccuracy",
                        "SparseCategoricalCrossentropy",
                        "SparseTopKCategoricalAccuracy",
                        "SpecificityAtSensitivity",
                        "SquaredHinge",
                        "Sum",
                        "TopKCategoricalAccuracy",
                        "TrueNegatives",
                        "TruePositives"
                    ],
                    "default": "accuracy"
                },
                "training_loss": {
                    "$id": "#/properties/model/properties/training_loss",
                    "type": "string",
                    "title": "Loss function.",
                    "description": "Loss function.",
                    "enum": [
                        "KLD",
                        "MAE",
                        "MAPE",
                        "MSE",
                        "MSLE",
                        "binary_crossentropy",
                        "categorical_crossentropy",
                        "categorical_hinge",
                        "cosine_similarity",
                        "deserialize",
                        "get",
                        "hinge",
                        "huber",
                        "kl_divergence",
                        "kld",
                        "kullback_leibler_divergence",
                        "log_cosh",
                        "logcosh",
                        "mae",
                        "mape",
                        "mean_absolute_error",
                        "mean_absolute_percentage_error",
                        "mean_squared_error",
                        "mean_squared_logarithmic_error",
                        "mse",
                        "msle",
                        "poisson",
                        "serialize",
                        "sparse_categorical_crossentropy",
                        "squared_hinge"
                    ],
                    "default": "mse"
                },
                "early_stopping_metric":  {
                    "$id": "#/properties/model/properties/early_stopping_metric",
                    "type": "string",
                    "title": "Early Stopping metric.",
                    "description": "Metric used by the early stopping.",
                    "enum": [
                        "val_accuracy",
                        "val_loss"
                    ],
                    "default": "val_accuracy"
                },
                "early_stopping_mode": {
                    "$id": "#/properties/model/properties/early_stopping_metric_threshold",
                    "type": "string",
                    "title": "Early stopping metric mode.",
                    "description": " In min mode, training will stop when the quantity monitored has stopped decreasing; in max mode it will stop when the quantity monitored has stopped increasing; in auto mode, the direction is automatically inferred from the name of the monitored quantity",
                    "enum": ["min", "max", "auto"],
                    "default": "min"
                },
                "early_stopping_patience": {
                    "$id": "#/properties/model/properties/early_stopping_metric_threshold",
                    "type": "number",
                    "title": "Early stopping metric patience.",
                    "description": "Number of epochs with no improvement after which training will be stopped.",
                    "default": 5
                },
                "early_stopping_restore_best_weights": {
                    "$id": "#/properties/model/properties/early_stopping_restore_best_weights",
                    "type": "boolean",
                    "title": "Early Stopping restore best weights.",
                    "description": "Whether to restore model weights from the epoch with the best value of the monitored quantity.",
                    "default": true
                },
                "initial_epoch": {
                    "$id": "#/properties/model/properties/initial_epoch",
                    "type": "integer",
                    "title": "Initial epoch.",
                    "description": "Integer. Initial epoch.",
                    "default": 0
                },
                "epochs": {
                    "$id": "#/properties/model/properties/epochs",
                    "type": "integer",
                    "title": "Epochs.",
                    "description": "Integer. Number of epochs.",
                    "default": 100
                }
            }
        }
    }
}
