{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "http://example.com/example.json",
    "type": "object",
    "title": "ST Edge.AI Schema for inertial classification.",
    "description": "ST Edge.AI Schema to configure inertial classification jupyter notebook template.",
    "version": "v1",
    "required": [
        "general",
        "resampling",
        "model"
    ],
    "properties": {
        "general": {
            "$id": "#/properties/general",
            "type": "object",
            "title": "General parameters.",
            "description": "General parameters.",
            "default": {},
            "required": [
                "project",
                "model",
                "classes",
                "experiment"
            ],
            "properties": {
                "project": {
                    "$id": "#/properties/general/properties/project",
                    "type": "string",
                    "title": "Project name.",
                    "description": "Name of the project.",
                    "default": ""
                },
                "model": {
                    "$id": "#/properties/general/properties/model",
                    "type": "string",
                    "title": "Model name.",
                    "description": "Name of the model.",
                    "default": ""
                },
                "classes": {
                    "$id": "#/properties/general/properties/classes",
                    "type": "array",
                    "title": "Classes names.",
                    "description": "Name of the classes.",
                    "default": [],
                    "additionalItems": true,
                    "items": {
                        "anyOf": [
                            {
                                "$id": "#/properties/general/properties/classes/items/anyOf/0",
                                "type": "string",
                                "title": "Class name.",
                                "description": "Name of the class.",
                                "default": ""
                            }
                        ]
                    }
                },
                "experiment": {
                    "$id": "#/properties/general/properties/experiment",
                    "type": "string",
                    "title": "Experiment name.",
                    "description": "Name of the experiment.",
                    "default": ""
                }
            }
        },
        "resampling": {
            "$id": "#/properties/resampling",
            "type": "object",
            "title": "Resampling parameters.",
            "description": "Resampling parameters.",
            "default": {},
            "required": [
                "resampling_active",
                "resampling_frequency"
            ],
            "properties": {
                "resampling_active": {
                    "type": "boolean",
                    "default":  false
                },
                "resampling_frequency": {
                    "type": "number",
                    "enum":  [12.5, 26.0, 52.0, 104.0, 208.0, 417.0, 833.0, 1667.0, 3333.0, 6667.0]
                }
            }
        },
        "model": {
            "$id": "#/properties/model",
            "type": "object",
            "title": "Model parameters.",
            "description": "Model parameters.",
            "default": {},
            "required": [
                "number_of_welch_segments",
                "batch_size",
                "optimizer",
                "learning_rate",
                "decay_rate",
                "training_metric",
                "training_loss",
                "early_stopping_metric",
                "early_stopping_mode",
                "early_stopping_patience",
                "early_stopping_restore_best_weights",
                "initial_epoch",
                "epochs"
            ],
            "properties": {
                "number_of_welch_segments": {
                    "$id": "#/properties/model/properties/number_of_welch_segments",
                    "type": "integer",
                    "title": "Number of averages.",
                    "description": "Integer. Number of overlapping segments used to compute the estimate power spectral density of the data by using the Welch's method.",
                    "default": 50
                },
                "batch_size": {
                    "$id": "#/properties/model/properties/batch_size",
                    "type": "integer",
                    "title": "Batch size.",
                    "description": "Integer. Size of the batches of data.",
                    "default": 128
                },
                "optimizer": {
                    "$id": "#/properties/model/properties/optimizer",
                    "type": "string",
                    "title": "Optimizer.",
                    "description": "Optimizer.",
                    "enum": [
                        "Adadelta",
                        "Adagrad",
                        "Adam",
                        "Adamax",
                        "Ftrl",
                        "Nadam",
                        "RMSprop",
                        "SGD"
                    ],
                    "default": "Adam"
                },
                "learning_rate": {
                    "$id": "#/properties/model/properties/learning_rate",
                    "type": "number",
                    "title": "Learning rate.",
                    "description": "Float. Learning rate.",
                    "default": 1e-4
                },
                "decay_rate": {
                    "$id": "#/properties/model/properties/decay_rate",
                    "type": "number",
                    "title": "Decay rate.",
                    "description": "Float. Decay rate.",
                    "default": 1e-6
                },
                "training_metric": {
                    "$id": "#/properties/model/properties/training_metric",
                    "type": "string",
                    "title": "Metric name.",
                    "description": "Name of the metric.",
                    "enum": [
                        "accuracy",
                        "crossentropy",
                        "AUC",
                        "Accuracy",
                        "BinaryAccuracy",
                        "BinaryCrossentropy",
                        "CategoricalAccuracy",
                        "CategoricalCrossentropy",
                        "CategoricalHinge",
                        "CosineSimilarity",
                        "FalseNegatives",
                        "FalsePositives",
                        "Hinge",
                        "KLDivergence",
                        "LogCoshError",
                        "Mean",
                        "MeanAbsoluteError",
                        "MeanAbsolutePercentageError",
                        "MeanIoU",
                        "MeanRelativeError",
                        "MeanSquaredError",
                        "MeanSquaredLogarithmicError",
                        "MeanTensor",
                        "Metric",
                        "Poisson",
                        "Precision",
                        "PrecisionAtRecall",
                        "Recall",
                        "RecallAtPrecision",
                        "RootMeanSquaredError",
                        "SensitivityAtSpecificity",
                        "SparseCategoricalAccuracy",
                        "SparseCategoricalCrossentropy",
                        "SparseTopKCategoricalAccuracy",
                        "SpecificityAtSensitivity",
                        "SquaredHinge",
                        "Sum",
                        "TopKCategoricalAccuracy",
                        "TrueNegatives",
                        "TruePositives"
                    ],
                    "default": "accuracy"
                },
                "training_loss": {
                    "$id": "#/properties/model/properties/training_loss",
                    "type": "string",
                    "title": "Loss function.",
                    "description": "Loss function.",
                    "enum": [
                        "KLD",
                        "MAE",
                        "MAPE",
                        "MSE",
                        "MSLE",
                        "binary_crossentropy",
                        "categorical_crossentropy",
                        "categorical_hinge",
                        "cosine_similarity",
                        "deserialize",
                        "get",
                        "hinge",
                        "huber",
                        "kl_divergence",
                        "kld",
                        "kullback_leibler_divergence",
                        "log_cosh",
                        "logcosh",
                        "mae",
                        "mape",
                        "mean_absolute_error",
                        "mean_absolute_percentage_error",
                        "mean_squared_error",
                        "mean_squared_logarithmic_error",
                        "mse",
                        "msle",
                        "poisson",
                        "serialize",
                        "sparse_categorical_crossentropy",
                        "squared_hinge"
                    ],
                    "default": "categorical_crossentropy"
                },
                "early_stopping_metric": {
                    "$id": "#/properties/model/properties/early_stopping_metric",
                    "type": "string",
                    "title": "Early Stopping metric.",
                    "description": "Metric used by the early stopping.",
                    "enum": [
                        "val_accuracy",
                        "val_loss"
                    ],
                    "default": "val_accuracy"
                },
                "early_stopping_mode": {
                    "$id": "#/properties/model/properties/early_stopping_mode",
                    "type": "string",
                    "title": "Early Stopping mode.",
                    "description": "Threshold on the metric used by the early stopping.",
                    "default": [
                        "auto",
                        "min",
                        "max"
                    ]
                },
                "early_stopping_patience": {
                    "$id": "#/properties/model/properties/early_stopping_patience",
                    "type": "integer",
                    "title": "Early Stopping patience.",
                    "description": "Number of epochs with no improvement after which training will be stopped.",
                    "default": 0
                },
                "early_stopping_restore_best_weights": {
                    "$id": "#/properties/model/properties/early_stopping_restore_best_weights",
                    "type": "boolean",
                    "title": "Early Stopping restore best weights.",
                    "description": "Whether to restore model weights from the epoch with the best value of the monitored quantity.",
                    "default": true
                },
                "initial_epoch": {
                    "$id": "#/properties/model/properties/initial_epoch",
                    "type": "integer",
                    "title": "Initial epoch.",
                    "description": "Integer. Initial epoch.",
                    "default": 0
                },
                "epochs": {
                    "$id": "#/properties/model/properties/epochs",
                    "type": "integer",
                    "title": "Epochs.",
                    "description": "Integer. Number of epochs.",
                    "default": 5000
                }
            }
        }
	}
}
